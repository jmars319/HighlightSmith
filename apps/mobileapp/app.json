{
  "expo": {
    "name": "vaexcore pulse companion",
    "slug": "vaexcore-pulse-companion",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/vaexcore-pulse-logo.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.vaexil.vaexcore.pulse.mobile"
    },
    "android": {
      "package": "com.vaexil.vaexcore.pulse.mobile",
      "edgeToEdgeEnabled": true
    },
    "experiments": {
      "autolinkingModuleResolution": true
    },
    "splash": {
      "image": "./assets/vaexcore-pulse-logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#02040a"
    },
    "extra": {
      "surfaceRole": "companion-only"
    }
  }
}
