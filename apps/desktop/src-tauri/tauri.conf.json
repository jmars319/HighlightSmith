{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "HighlightSmith",
  "version": "0.1.0",
  "identifier": "com.highlightsmith.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev:web",
    "beforeBuildCommand": "pnpm build:web",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "HighlightSmith",
        "width": 1540,
        "height": 960,
        "minWidth": 1120,
        "minHeight": 760,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": false
  }
}
