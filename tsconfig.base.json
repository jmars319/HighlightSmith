{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "paths": {
      "@vaexcore/pulse-shared-types": [
        "./packages/shared-types/src/index.ts"
      ],
      "@vaexcore/pulse-domain": ["./packages/domain/src/index.ts"],
      "@vaexcore/pulse-ui": ["./packages/ui/src/index.ts"],
      "@vaexcore/pulse-storage": ["./packages/storage/src/index.ts"],
      "@vaexcore/pulse-media": ["./packages/media/src/index.ts"],
      "@vaexcore/pulse-scoring": ["./packages/scoring/src/index.ts"],
      "@vaexcore/pulse-profiles": ["./packages/profiles/src/index.ts"],
      "@vaexcore/pulse-export": ["./packages/export/src/index.ts"],
      "@vaexcore/pulse-ai-assist": ["./packages/ai-assist/src/index.ts"]
    }
  }
}
