{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@highlightsmith/shared": ["packages/shared/src/index.ts"],
      "@highlightsmith/storage": ["packages/storage/src/index.ts"],
      "@highlightsmith/media": ["packages/media/src/index.ts"],
      "@highlightsmith/scoring": ["packages/scoring/src/index.ts"],
      "@highlightsmith/profiles": ["packages/profiles/src/index.ts"],
      "@highlightsmith/export": ["packages/export/src/index.ts"]
    }
  }
}
